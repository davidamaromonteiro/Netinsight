# NetInsight Backend – Environment Configuration
# Copy to .env : cp .env.example .env
# Or run : ./setup.sh (auto-generates .env)

APP_NAME=NetInsight API
APP_VERSION=0.3.0
DEBUG=false

# Security (will be auto-generated by setup.sh)
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# MongoDB
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=netinsight

# Redis
REDIS_URL=redis://redis:6379/0

# NVD API (optionnel — rate-limited sans clé, ~6 req/30s)
NVD_API_KEY=
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# MITRE ATT&CK
MITRE_ENTERPRISE_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack.json

# Scan defaults
SCAN_RATE_LIMIT=100
SCAN_TIMEOUT_SECONDS=300

# CORS
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:5173"]
